{
  "name": "be-pmtl",
  "version": "0.1.0",
  "private": true,
  "description": "A Strapi application",
  "scripts": {
    "postinstall": "node scripts/patch-soft-delete-plugin.mjs && node scripts/patch-tree-menus-plugin.mjs",
    "prebuild": "node scripts/ensure-admin-vi.mjs",
    "build": "node --max-old-space-size=4096 ./node_modules/@strapi/strapi/bin/strapi.js build",
    "console": "node --max-old-space-size=4096 ./node_modules/@strapi/strapi/bin/strapi.js console",
    "dev:kill": "pwsh.exe -ExecutionPolicy Bypass -File ..\\scripts\\kill-dev.ps1",
    "dev:kill:all": "pwsh.exe -ExecutionPolicy Bypass -File ..\\scripts\\kill-dev.ps1 -IncludeDatabases -Aggressive",
    "deploy": "node --max-old-space-size=4096 ./node_modules/@strapi/strapi/bin/strapi.js deploy",
    "dev": "node --max-old-space-size=4096 ./node_modules/@strapi/strapi/bin/strapi.js develop",
    "develop": "node --max-old-space-size=4096 ./node_modules/@strapi/strapi/bin/strapi.js develop",
    "seed:core": "npm run build && node scripts/seed-test.js",
    "seed:ui-icons": "npm run build && node scripts/seed-ui-icons.js",
    "seed:rich": "npm run build && node scripts/seed-rich.js",
    "seed:bulk": "npm run build && node scripts/seed-internal.js",
    "i18n:vi:fields": "node scripts/generate-admin-vi-fields.mjs",
    "i18n:vi:merge": "node scripts/build-admin-vi.mjs",
    "i18n:vi": "npm run i18n:vi:fields && npm run i18n:vi:merge",
    "reindex:blog-post": "npm run build && node scripts/reindex-search.js blog-post",
    "reindex:all": "npm run build && node scripts/reindex-search.js all",
    "seed:full": "npm run build && node scripts/seed-full.js",
    "start": "node --max-old-space-size=4096 ./node_modules/@strapi/strapi/bin/strapi.js start",
    "strapi": "node --max-old-space-size=4096 ./node_modules/@strapi/strapi/bin/strapi.js",
    "smoke:prod": "node scripts/smoke-prod.mjs",
    "types:generate": "node scripts/strapi-types-runner.mjs generate",
    "types:check": "node scripts/strapi-types-runner.mjs check",
    "types:watch": "node scripts/strapi-types-runner.mjs watch",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watchAll",
    "upgrade": "npx @strapi/upgrade latest",
    "upgrade:dry": "npx @strapi/upgrade latest --dry"
  },
  "dependencies": {
    "@_sh/strapi-plugin-ckeditor": "^7.0.0",
    "@offset-dev/strapi-calendar": "^1.0.0",
    "@samuel-erb/strapi-plugin-lucide-icon-picker": "^1.1.0",
    "@strapi-community/plugin-redis": "^2.0.0",
    "@strapi/plugin-documentation": "^5.38.0",
    "@strapi/plugin-users-permissions": "5.38.0",
    "@strapi/provider-email-nodemailer": "5.38.0",
    "@strapi/strapi": "5.38.0",
    "axios": "^1.13.6",
    "better-sqlite3": "12.4.1",
    "export-import-kkm": "^1.1.1",
    "fs-extra": "^11.3.3",
    "pg": "^8.19.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "strapi-advanced-uuid": "^2.1.1",
    "strapi-plugin-bullmq": "^1.0.1",
    "strapi-plugin-meilisearch": "^0.15.0",
    "strapi-plugin-rate-limit": "^0.4.0",
    "strapi-plugin-soft-delete-contents": "^1.0.5",
    "styled-components": "^6.0.0",
    "tree-menus": "^1.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/supertest": "^7.2.0",
    "jest": "^30.2.0",
    "strapi-typed-client": "^1.3.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20.0.0 <=24.x.x",
    "npm": ">=6.0.0"
  },
  "strapi": {
    "uuid": "ac982ec2-4bd6-41ee-b298-34861ea4bf2e",
    "installId": "774f851528ab075df9b1143cb2983df0e574fe9ff6747133786c8b9de67a347c"
  }
}
