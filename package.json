    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "strapi-plugin-meilisearch": "^0.15.0",
    "styled-components": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
