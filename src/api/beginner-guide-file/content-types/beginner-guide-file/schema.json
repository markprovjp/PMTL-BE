{
  "kind": "collectionType",
  "collectionName": "beginner_guide_files",
  "info": {
    "singularName": "beginner-guide-file",
    "pluralName": "beginner-guide-files",
    "displayName": "Hướng Dẫn Sơ Học - File",
    "description": "Tài liệu PDF / file hướng dẫn sơ học cho người mới"
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "order": {
      "type": "integer",
      "default": 1
    },
    "files": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["files", "images"]
    }
  }
}
