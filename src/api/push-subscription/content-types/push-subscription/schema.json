{
  "kind": "collectionType",
  "collectionName": "push_subscriptions",
  "info": {
    "singularName": "push-subscription",
    "pluralName": "push-subscriptions",
    "displayName": "Thiết Bị · Đăng Ký Nhận Thông Báo",
    "description": "Mỗi dòng là một thiết bị đã bật nhận thông báo trên web"
  },
  "options": {
    "draftAndPublish": false,
    "increments": true,
    "timestamps": true
  },
  "pluginOptions": {},
  "attributes": {
    "endpoint": {
      "type": "text",
      "required": true
    },
    "p256dh": {
      "type": "string",
      "required": true,
      "maxLength": 500
    },
    "auth": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "reminderHour": {
      "type": "integer",
      "default": 6,
      "min": 0,
      "max": 23
    },
    "reminderMinute": {
      "type": "integer",
      "default": 0,
      "min": 0,
      "max": 59
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "timezone": {
      "type": "string",
      "default": "Asia/Ho_Chi_Minh",
      "maxLength": 100
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "lastSentAt": {
      "type": "datetime"
    },
    "lastError": {
      "type": "text"
    },
    "failedCount": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "notificationTypes": {
      "type": "json"
    },
    "quietHoursStart": {
      "type": "integer",
      "default": 22,
      "min": 0,
      "max": 23
    },
    "quietHoursEnd": {
      "type": "integer",
      "default": 6,
      "min": 0,
      "max": 23
    },
    "uuid": {
      "type": "customField",
      "customField": "plugin::strapi-advanced-uuid.uuid"
    }
  }
}
