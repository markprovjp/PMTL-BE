{
  "kind": "collectionType",
  "collectionName": "guestbook_entries",
  "info": {
    "singularName": "guestbook-entry",
    "pluralName": "guestbook-entries",
    "displayName": "Cộng Đồng · Sổ Lưu Bút",
    "description": "Guestbook — lưu bút từ khách thập phương"
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "authorName": {
      "type": "string",
      "required": true,
      "maxLength": 100
    },
    "country": {
      "type": "string",
      "maxLength": 100
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "message": {
      "type": "text",
      "required": true,
      "minLength": 5,
      "maxLength": 2000
    },
    "adminReply": {
      "type": "text",
      "maxLength": 2000
    },
    "approvalStatus": {
      "type": "enumeration",
      "enum": ["pending", "approved"],
      "default": "pending",
      "required": true
    },
    "isOfficialReply": {
      "type": "boolean",
      "default": false,
      "description": "true = Đây là phản hồi chính thức từ Ban Quản Trị (hiển thị khung viền vàng)"
    },
    "badge": {
      "type": "string",
      "maxLength": 50,
      "default": null,
      "description": "Nhãn hiển thị — ví dụ: 'Ban Quản Trị' nebo 'Đông Phương Đài'"
    },
    "year": {
      "type": "integer",
      "description": "Năm gửi (denorm để filter archive nhanh)",
      "index": true
    },
    "month": {
      "type": "integer",
      "description": "Tháng gửi (dùng phân loại theo tháng)",
      "index": true
    },
    "entryType": {
      "type": "enumeration",
      "enum": ["message", "question"],
      "default": "message"
    },
    "questionCategory": {
      "type": "string",
      "maxLength": 100
    },
    "isAnswered": {
      "type": "boolean",
      "default": false
    }
  }
}
