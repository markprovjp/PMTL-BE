{
  "kind": "collectionType",
  "collectionName": "community_comments",
  "info": {
    "singularName": "community-comment",
    "pluralName": "community-comments",
    "displayName": "Bình Luận Cộng Đồng"
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "content": {
      "type": "text",
      "required": true
    },
    "author_name": {
      "type": "string",
      "required": true,
      "maxLength": 100
    },
    "author_country": {
      "type": "string",
      "maxLength": 100
    },
    "author_avatar": {
      "type": "string"
    },
    "user_id": {
      "type": "integer",
      "default": 0
    },
    "post": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::community-post.community-post",
      "inversedBy": "comments"
    },
    "likes": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "parent_id": {
      "type": "integer",
      "default": 0
    }
  }
}
