{
  "kind": "collectionType",
  "collectionName": "community_comments",
  "info": {
    "singularName": "community-comment",
    "pluralName": "community-comments",
    "displayName": "Cộng Đồng · Bình Luận CĐ"
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "content": {
      "type": "text",
      "required": true,
      "minLength": 1,
      "maxLength": 2000
    },
    "author_name": {
      "type": "string",
      "required": true,
      "maxLength": 100,
      "description": "Snapshot tên tác giả tại thời điểm gửi"
    },
    "author_avatar": {
      "type": "string",
      "maxLength": 500,
      "description": "URL avatar snapshot (cho khách chưa đăng nhập)"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "description": "Liên kết user đã đăng nhập (nullable — guest comment để null)"
    },
    "post": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::community-post.community-post",
      "inversedBy": "comments"
    },
    "likes": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::community-comment.community-comment",
      "inversedBy": "replies"
    },
    "replies": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::community-comment.community-comment",
      "mappedBy": "parent"
    }
  }
}
