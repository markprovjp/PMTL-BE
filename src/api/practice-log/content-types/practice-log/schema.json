{
  "kind": "collectionType",
  "collectionName": "practice_logs",
  "info": {
    "singularName": "practice-log",
    "pluralName": "practice-logs",
    "displayName": "Niệm Kinh · Nhật Ký Tu Học",
    "description": "Lưu tiến độ niệm kinh theo ngày + người dùng"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "required": true
    },
    "plan": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::chant-plan.chant-plan",
      "description": "Chant plan đang dùng (dùng relation, không cần slug rời)"
    },
    "date": {
      "type": "date",
      "required": true,
      "description": "Ngày tu học (YYYY-MM-DD)"
    },
    "itemsProgress": {
      "type": "json",
      "description": "Map: { [itemSlug]: { count: number, done: boolean } }"
    },
    "startedAt": {
      "type": "datetime",
      "description": "Thời điểm bắt đầu tu học trong ngày"
    },
    "completedAt": {
      "type": "datetime",
      "description": "Thời điểm hoàn thành tất cả bài (nếu có)"
    },
    "isCompleted": {
      "type": "boolean",
      "default": false,
      "description": "Đã hoàn thành toàn bộ plan trong ngày này chưa"
    },
    "uuid": {
      "type": "customField",
      "customField": "plugin::strapi-advanced-uuid.uuid"
    }
  }
}
