{
  "kind": "collectionType",
  "collectionName": "lunar_events",
  "info": {
    "singularName": "lunar-event",
    "pluralName": "lunar-events",
    "displayName": "Niệm Kinh · Lịch Sự Kiện Âm",
    "description": "Lịch niệm Lễ Phật Đại Sám Hối Văn, khai thị và các ngày vía"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "isRecurringLunar": {
      "type": "boolean",
      "default": true
    },
    "lunarMonth": {
      "type": "integer",
      "min": 1,
      "max": 12
    },
    "lunarDay": {
      "type": "integer",
      "min": 1,
      "max": 30
    },
    "solarDate": {
      "type": "date"
    },
    "eventType": {
      "type": "enumeration",
      "enum": [
        "buddha",
        "bodhisattva",
        "teacher",
        "fast",
        "holiday",
        "normal"
      ],
      "default": "normal",
      "description": "Priority: holiday(5) > fast(4) > buddha(3) > bodhisattva(2) > teacher(1) > normal(0). Xác định ưu tiên của sự kiện khi nhập override."
    },
    "relatedBlogs": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::blog-post.blog-post",
      "inversedBy": "lunarEvents",
      "description": "Liên kết các bài blog khai thị liên quan đến sự kiện này"
    }
  }
}
