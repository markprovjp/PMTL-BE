{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Nội Dung · Sự Kiện",
    "description": "Quản lý sự kiện, pháp hội, phóng sinh tại Việt Nam"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "content": {
      "type": "richtext"
    },
    "date": {
      "type": "date"
    },
    "timeString": {
      "type": "string"
    },
    "location": {
      "type": "string",
      "required": true,
      "default": "Việt Nam"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "dharma-talk",
        "webinar",
        "retreat",
        "liberation",
        "festival"
      ],
      "default": "dharma-talk",
      "required": true
    },
    "eventStatus": {
      "type": "enumeration",
      "enum": [
        "upcoming",
        "live",
        "past"
      ],
      "default": "upcoming",
      "required": true
    },
    "speaker": {
      "type": "string",
      "default": "Đội ngũ giảng sư"
    },
    "language": {
      "type": "string",
      "default": "Tiếng Việt"
    },
    "link": {
      "type": "string"
    },
    "youtubeId": {
      "type": "string"
    },
    "oembed": {
      "type": "string",
      "maxLength": 500
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "videos"
      ]
    },
    "files": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "files"
      ]
    },
    "uuid": {
      "type": "customField",
      "customField": "plugin::strapi-advanced-uuid.uuid"
    }
  }
}
