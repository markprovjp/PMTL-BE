{
  "kind": "collectionType",
  "collectionName": "content_histories",
  "info": {
    "singularName": "content-history",
    "pluralName": "content-histories",
    "displayName": "System · Content History",
    "description": "Internal versioned snapshots for content changes"
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "targetUid": {
      "type": "string",
      "required": true,
      "maxLength": 150
    },
    "targetDocumentId": {
      "type": "string",
      "required": true,
      "maxLength": 255
    },
    "targetId": {
      "type": "integer"
    },
    "targetLabel": {
      "type": "string",
      "maxLength": 255
    },
    "action": {
      "type": "enumeration",
      "enum": [
        "create",
        "update",
        "delete",
        "publish",
        "unpublish"
      ],
      "required": true
    },
    "versionNumber": {
      "type": "integer",
      "required": true,
      "min": 1
    },
    "actorType": {
      "type": "enumeration",
      "enum": [
        "admin",
        "user",
        "guest",
        "system"
      ],
      "required": true
    },
    "actorId": {
      "type": "integer"
    },
    "actorDisplayName": {
      "type": "string",
      "maxLength": 255
    },
    "actorEmail": {
      "type": "email"
    },
    "changedFields": {
      "type": "json"
    },
    "snapshot": {
      "type": "json",
      "required": true
    },
    "metadata": {
      "type": "json"
    },
    "uuid": {
      "type": "customField",
      "customField": "plugin::strapi-advanced-uuid.uuid"
    }
  }
}
