{
  "kind": "collectionType",
  "collectionName": "community_posts",
  "info": {
    "singularName": "community-post",
    "pluralName": "community-posts",
    "displayName": "Cộng Đồng · Bài Đăng"
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 300
    },
    "content": {
      "type": "text",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": ["story", "feedback", "video"],
      "default": "story",
      "required": true,
      "description": "story = chia sẻ kinh nghiệm, feedback = phản hồi, video = đính kèm video"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "Sức Khoẻ",
        "Gia Đình",
        "Sự Nghiệp",
        "Hôn Nhân",
        "Tâm Linh",
        "Thi Cử",
        "Kinh Doanh",
        "Mất Ngủ",
        "Mối Quan Hệ",
        "Khác"
      ],
      "default": "Tâm Linh"
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "video_url": {
      "type": "string",
      "maxLength": 500
    },
    "author_name": {
      "type": "string",
      "required": true,
      "maxLength": 100,
      "description": "Snapshot tên tác giả tại thời điểm đăng"
    },
    "author_avatar": {
      "type": "string",
      "maxLength": 500,
      "description": "URL avatar snapshot (cho khách chưa đăng nhập)"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "description": "Liên kết user đã đăng nhập (nullable — anonymous để null)"
    },
    "likes": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "views": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "comments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::community-comment.community-comment",
      "mappedBy": "post"
    },
    "tags": {
      "type": "json",
      "description": "Mảng tag string (tự do, không chuẩn hoá)"
    },
    "rating": {
      "type": "integer",
      "min": 1,
      "max": 5
    },
    "pinned": {
      "type": "boolean",
      "default": false
    }
  }
}
