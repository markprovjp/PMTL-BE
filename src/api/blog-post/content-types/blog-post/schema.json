{
  "kind": "collectionType",
  "collectionName": "blog_posts",
  "info": {
    "singularName": "blog-post",
    "pluralName": "blog-posts",
    "displayName": "Nội Dung · Bài Viết",
    "description": "Bài viết Phật pháp (Khai Thị)"
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 200,
      "required": true,
      "index": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "maxLength": 200,
      "index": true
    },
    "content": {
      "type": "richtext",
      "required": true,
      "minLength": 10,
      "index": true
    },
    "excerpt": {
      "type": "string",
      "maxLength": 300,
      "description": "Tóm tắt ngắn tự động hoặc editor nhập tay (dùng cho danh sách bài)"
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    },
    "video_url": {
      "type": "string",
      "maxLength": 500
    },
    "audio_url": {
      "type": "string",
      "maxLength": 500
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "inversedBy": "blog_posts"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::blog-tag.blog-tag"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "index": true
    },
    "views": {
      "type": "integer",
      "default": 0,
      "min": 0,
      "description": "Tổng lượt xem (mỗi IP đếm 1 lần/giờ)"
    },
    "unique_views": {
      "type": "integer",
      "default": 0,
      "min": 0,
      "description": "Lượt xem unique theo session (dự phòng scale)"
    },
    "likes": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    },
    "related_posts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::blog-post.blog-post"
    },
    "lunarEvents": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::lunar-event.lunar-event",
      "mappedBy": "relatedBlogs"
    },
    "seriesKey": {
      "type": "string",
      "maxLength": 200,
      "index": true
    },
    "seriesNumber": {
      "type": "integer",
      "min": 1
    },
    "sourceName": {
      "type": "string",
      "maxLength": 200,
      "description": "Tên nguồn/kênh (ví dụ: wenda20140829)"
    },
    "sourceUrl": {
      "type": "string",
      "maxLength": 500,
      "description": "URL bài gốc nếu là repost/dịch"
    },
    "sourceTitle": {
      "type": "string",
      "maxLength": 200,
      "description": "Tiêu đề gốc (tiếng Trung hoặc ngôn ngữ gốc)"
    },
    "allowComments": {
      "type": "boolean",
      "default": true,
      "description": "Bật/tắt bình luận cho bài này. Tắt khi Admin khóa."
    },
    "commentCount": {
      "type": "integer",
      "default": 0,
      "min": 0,
      "description": "Số bình luận đã duyệt (denorm để hiển thị nhanh)"
    },
    "eventDate": {
      "type": "date",
      "description": "Ngày tổ chức sự kiện (dùng cho các bài giảng có ngày cụ thể)"
    },
    "location": {
      "type": "string",
      "maxLength": 200,
      "description": "Địa điểm tổ chức (ví dụ: Hồ Chí Minh, Úc, Đài Loan)"
    }
  }
}
