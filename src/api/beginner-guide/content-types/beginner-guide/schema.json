{
  "kind": "collectionType",
  "collectionName": "beginner_guides",
  "info": {
    "singularName": "beginner-guide",
    "pluralName": "beginner-guides",
    "displayName": "Hướng Dẫn Sơ Học",
    "description": "Quản lý các bước hướng dẫn sơ học và kinh bài tập hằng ngày"
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "pmtl-html"
      }
    },
    "content": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "pmtl-html"
      }
    },
    "details": {
      "type": "json",
      "required": false
    },
    "duration": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "default": 1
    },
    "step_number": {
      "type": "integer",
      "default": 1
    },
    "guide_type": {
      "type": "enumeration",
      "enum": ["so-hoc", "kinh-bai-tap"],
      "default": "so-hoc",
      "required": true
    },
    "icon": {
      "type": "string",
      "default": "BookOpen"
    },
    "pdf_url": {
      "type": "string",
      "maxLength": 500
    },
    "video_url": {
      "type": "string",
      "maxLength": 500
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    }
  }
}
