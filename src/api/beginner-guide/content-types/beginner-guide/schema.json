{
  "kind": "collectionType",
  "collectionName": "beginner_guides",
  "info": {
    "singularName": "beginner-guide",
    "pluralName": "beginner-guides",
    "displayName": "Nội Dung · Hướng Dẫn Sơ Học",
    "description": "Quản lý các bước hướng dẫn sơ học và kinh bài tập hằng ngày"
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "content": {
      "type": "richtext"
    },
    "details": {
      "type": "json",
      "required": false
    },
    "duration": {
      "type": "string"
    },
    "order": {
      "type": "integer",
      "default": 1
    },
    "step_number": {
      "type": "integer",
      "default": 1
    },
    "guide_type": {
      "type": "enumeration",
      "enum": [
        "so-hoc",
        "kinh-bai-tap"
      ],
      "default": "so-hoc",
      "required": true
    },
    "icon": {
      "type": "string",
      "customField": "plugin::lucide-icon-picker.lucide-icon",
      "maxLength": 120
    },
    "pdf_url": {
      "type": "string",
      "maxLength": 500
    },
    "video_url": {
      "type": "string",
      "maxLength": 500
    },
    "images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "attached_files": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ],
      "description": "Tệp đính kèm (PDF, Word, Ảnh...)"
    },
    "uuid": {
      "type": "customField",
      "customField": "plugin::strapi-advanced-uuid.uuid"
    }
  }
}
