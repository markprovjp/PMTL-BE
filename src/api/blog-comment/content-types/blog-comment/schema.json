{
  "kind": "collectionType",
  "collectionName": "blog_comments",
  "info": {
    "singularName": "blog-comment",
    "pluralName": "blog-comments",
    "displayName": "Cộng Đồng · Bình Luận Blog",
    "description": "Bình luận bài viết blog (có kiểm duyệt)"
  },
  "options": {
    "increments": true,
    "timestamps": true,
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "post": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::blog-post.blog-post"
    },
    "authorName": {
      "type": "string",
      "required": true,
      "maxLength": 100
    },
    "authorAvatar": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "userId": {
      "type": "string",
      "maxLength": 100
    },
    "content": {
      "type": "text",
      "required": true,
      "minLength": 2,
      "maxLength": 2000
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::blog-comment.blog-comment",
      "inversedBy": "replies"
    },
    "replies": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::blog-comment.blog-comment",
      "mappedBy": "parent"
    },
    "likes": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "isOfficialReply": {
      "type": "boolean",
      "default": false,
      "description": "true = Reply chính thức từ Ban Quản Trị (hiển thị viền vàng nổi bật)"
    },
    "badge": {
      "type": "string",
      "maxLength": 50,
      "description": "Nhãn hiển thị kèm tên — ví dụ: 'Ban Quản Trị' hoặc 'Thầy Pháp Su'",
      "default": null
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "description": "Liên kết user đăng nhập (nullable — khách không đăng nhập để null)"
    },
    "ipHash": {
      "type": "string",
      "maxLength": 64,
      "description": "Hash IP để rate-limit (không lưu thật)"
    },
    "moderationStatus": {
      "type": "enumeration",
      "enum": ["visible", "flagged", "hidden", "removed"],
      "default": "visible"
    },
    "reportCount": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "lastReportReason": {
      "type": "string",
      "maxLength": 50
    },
    "isHidden": {
      "type": "boolean",
      "default": false
    },
    "spamScore": {
      "type": "integer",
      "default": 0,
      "min": 0
    }
  }
}
