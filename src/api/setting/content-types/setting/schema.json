{
  "kind": "singleType",
  "collectionName": "settings",
  "info": {
    "singularName": "setting",
    "pluralName": "settings",
    "displayName": "Cấu Hình · Hệ Thống Trang Chủ",
    "description": "Cài đặt chung và nội dung trang chủ"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "siteTitle": {
      "type": "string",
      "required": true,
      "default": "Pháp Môn Tâm Linh"
    },
    "siteDescription": {
      "type": "text",
      "required": true,
      "default": "Trang thông tin Phật pháp và tu tập"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "socialLinks": {
      "type": "json",
      "required": false
    },
    "contactEmail": {
      "type": "email",
      "required": false
    },
    "contactPhone": {
      "type": "string",
      "maxLength": 20
    },
    "address": {
      "type": "text"
    },
    "footerText": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "pmtl-html"
      }
    },
    "heroSlides": {
      "type": "component",
      "repeatable": true,
      "component": "homepage.hero-slide"
    },
    "stats": {
      "type": "component",
      "repeatable": true,
      "component": "homepage.stat-item"
    },
    "phapBao": {
      "type": "component",
      "repeatable": true,
      "component": "homepage.phap-bao-item"
    },
    "actionCards": {
      "type": "component",
      "repeatable": true,
      "component": "homepage.action-card-item"
    },
    "featuredVideos": {
      "type": "component",
      "repeatable": true,
      "component": "homepage.featured-video"
    },
    "awards": {
      "type": "component",
      "repeatable": true,
      "component": "homepage.award-item"
    },
    "gallerySlides": {
      "type": "component",
      "repeatable": true,
      "component": "homepage.gallery-slide"
    },
    "stickyBanner": {
      "type": "component",
      "repeatable": false,
      "component": "homepage.sticky-banner"
    }
  }
}
