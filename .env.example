HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified
CLIENT_URL=http://localhost:3000
# Optional. Set this only when frontend already has /api/preview draft-mode route.
PREVIEW_SECRET=
PREVIEW_ENABLED=true
PREVIEW_ROUTE=/api/preview
# Optional CSV list. Example: https://pmtl.vn,https://www.pmtl.vn
PREVIEW_ALLOWED_ORIGINS=http://localhost:3000

# Meilisearch
# Backend/plugin needs an admin-capable key. In most setups this is the master key.
MEILISEARCH_ENABLED=true
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your_meilisearch_master_key
MEILISEARCH_BLOG_POST_INDEX=blog-post
